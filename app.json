{
  "expo": {
    "name": "PesoNest",
    "slug": "pesonest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/pesonest-app-icon.png",
    "scheme": "pesonest",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FDF1E7",
    "splash": {
      "image": "./assets/images/pesonest-app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF1E7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pesonest.app",
      "infoPlist": {
        "NSCameraUsageDescription": "PesoNest needs camera access to scan QR codes for joint loans."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-adaptive-icon.png",
        "backgroundColor": "#FDF1E7"
      },
      "package": "com.pesonest.app"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-camera",
        { "cameraPermission": "PesoNest needs camera access to scan QR codes." }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FDF1E7",
          "image": "./assets/images/pesonest-app-icon.png",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
