{
  "expo": {
    "name": "PesoNest",
    "slug": "pesonest",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "pesonest",
    "userInterfaceStyle": "light",
    "backgroundColor": "#FDF1E7",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF1E7"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pesonest.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FDF1E7"
      },
      "package": "com.pesonest.app"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FDF1E7",
          "image": "./assets/splash.png",
          "resizeMode": "contain"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
